{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,

    "moduleResolution": "node",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "sourceMap": true,

    "resolveJsonModule": true,

    "types": ["node"],

    "ignoreDeprecations": "6.0"
  },

  "include": [
    "src/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}